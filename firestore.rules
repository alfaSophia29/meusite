rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').matches("(?i)^(ac926815124@gmail.com|alfaajmc@gmail.com)$") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (request.resource.data.get('isAdmin', false) == false || isAdmin());
      allow update: if isAdmin() || (
        isSignedIn() && (
          (isOwner(userId) && (
            // Owner can change fields. If balance is changed, it must NOT increase (spending is ok, self-funding is not)
            (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance']) || 
             request.resource.data.get('balance', 0) <= resource.data.get('balance', 0))
          )) ||
          (!isOwner(userId) && (
            // Others can only increase specific fields (like balance when paying or followers)
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'followers', 'monetizationGoals', 'monetizationStatus']) &&
            request.resource.data.get('balance', 0) >= resource.data.get('balance', 0)
          ))
        )
      );
      allow delete: if isAdmin();
    }

    match /public_profiles/{userId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isSignedIn() && (
          (isOwner(userId) && (
            (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance']) || 
             request.resource.data.get('balance', 0) <= resource.data.get('balance', 0))
          )) ||
          (!isOwner(userId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'followers', 'monetizationGoals', 'monetizationStatus', 'followedUsers']) &&
            request.resource.data.get('balance', 0) >= resource.data.get('balance', 0)
          ))
        )
      );
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'comments', 'shares', 'saves', 'views'])
      );
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || resource.data.get('isPublic', false) == true);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        resource.data.get('affiliateUserId', '') == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Allows creating transaction for self or if it's a SALE record being synced
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.type == 'SALE'
      );
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.professorId) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) &&
         get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.professorId == request.auth.uid) ||
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratings', 'averageRating', 'ratingCount', 'soldCount']))
      );
      allow delete: if isAdmin() || (
        exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) &&
        get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.professorId == request.auth.uid
      );
    }

    match /system_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /uniqueness_registry/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /blocks/{blockId} {
      allow get, list: if isSignedIn() && (resource.data.blockerId == request.auth.uid || resource.data.blockedId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.blockerId == request.auth.uid;
    }

    match /tickets/{ticketId} {
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read, update: if isAdmin();
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.professorId) || isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.creatorId) || isAdmin();
    }

    match /stories/{storyId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
       allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /earnings/{id} {
      allow read: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Allow creating earnings record 
      allow update: if isSignedIn(); // Allow updating (for impressions/donations)
    }

    match /super_chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /affiliate_links/{linkId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
